# Node.js .gitignore

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime files
.pnp.js
.pnp.cjs

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Dependency directories
node_modules/
jspm_packages/

# Build directories
dist/
build/

# Coverage directory used by tools like istanbul
coverage/

# dotenv environment variable file
.env
.env.test

# Next.js build output
.next/

# Nuxt.js build output
.nuxt/

# Sapper build output
__sapper__/export

# Serverless directories
.serverless/

# TypeScript v1 declaration files
*.d.ts

# Optional: Caching
.cache/

# Templating
/public

# IDE
.idea/
.vscode/